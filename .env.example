# Discord
CODEX_DISCORD_TOKEN=
CODEX_DISCORD_GUILD_ID=

# Discord Channels & Roles
CODEX_GM_ROLE_ID=your_gm_role_id
CODEX_GM_CHANNEL_ID=your_gm_channel_id
CODEX_PLAYER_CHANNEL_ID=your_player_channel_id

# Gemini API (audio transcription)
CODEX_GEMINI_API_KEY=your_gemini_api_key

# Anthropic / Claude (entity extraction, session summaries, /codex query)
CODEX_ANTHROPIC_API_KEY=your_anthropic_api_key
# CODEX_ANTHROPIC_MODEL=claude-sonnet-4-6

# Database (defaults to ./data/codex.db)
# CODEX_DB_PATH=./data/codex.db

# Audio input directory (defaults to ./inputs)
# CODEX_INPUT_DIR=./inputs

# Foundry VTT (Phase 5)
# CODEX_FOUNDRY_URL=http://localhost:30000
# CODEX_FOUNDRY_API_KEY=your_foundry_api_key

# Craig/rclone (Phase 3)
# CODEX_GDRIVE_CRAIG_PATH=gdrive:/Craig
