# living-codex — Environment Variables
# Copy this file to .env and fill in your values.
# All variables use the CODEX_ prefix.

# =============================================================================
# REQUIRED — Discord
# =============================================================================

# Your bot's token from https://discord.com/developers/applications
CODEX_DISCORD_TOKEN=your_discord_bot_token_here

# Numeric ID of your Discord server (right-click server → Copy Server ID)
CODEX_DISCORD_GUILD_ID=123456789012345678

# Role ID for the Game Master (right-click role → Copy Role ID)
CODEX_GM_ROLE_ID=123456789012345678

# Channel ID for GM-only messages
CODEX_GM_CHANNEL_ID=123456789012345678

# Channel ID for player-facing messages
CODEX_PLAYER_CHANNEL_ID=123456789012345678

# =============================================================================
# REQUIRED — AI model (set at least one API key)
# =============================================================================

# Which model to use for entity extraction, summarization, and queries.
# Prefix determines which API key is used:
#   claude-*  → CODEX_ANTHROPIC_API_KEY
#   gemini-*  → CODEX_GEMINI_API_KEY
#
# Options:
#   claude-haiku-4-5         (fast, cheap)
#   claude-sonnet-4-6        (balanced)
#   claude-opus-4-6          (most capable)
#   gemini-2.5-flash-lite    (fast, cheap)
#   gemini-2.5-pro           (more capable)
CODEX_AI_MODEL=claude-haiku-4-5

# Anthropic API key — required if CODEX_AI_MODEL starts with "claude-"
# Also accepted as CODEX_CLAUDE_API_KEY
CODEX_ANTHROPIC_API_KEY=sk-ant-...

# Google Gemini API key — required if CODEX_AI_MODEL starts with "gemini-"
# ALSO REQUIRED for audio transcription regardless of CODEX_AI_MODEL
# (Scribe pipeline always uses Gemini 2.0 Flash for transcription)
CODEX_GEMINI_API_KEY=AIza...

# =============================================================================
# OPTIONAL — Storage paths
# (defaults work for Docker; override for local dev or custom mounts)
# =============================================================================

# Path to the SQLite database file
# Default: ./data/codex.db
# CODEX_DB_PATH=./data/codex.db

# Directory watched for new audio files (Scribe pipeline input)
# Default: ./inputs
# In Docker this maps to /app/inputs (see docker-compose.yml volume mount)
# CODEX_INPUT_DIR=./inputs

# =============================================================================
# OPTIONAL — Foundry VTT sync
# Leave blank to disable Foundry integration entirely.
# =============================================================================

# Your Foundry VTT instance URL (e.g. https://forge-vtt.com/game/your-world)
CODEX_FOUNDRY_URL=

# Foundry VTT API key / JWT token
CODEX_FOUNDRY_API_KEY=

# =============================================================================
# OPTIONAL — Scribe pipeline settings
# =============================================================================

# Campaign ID to use as the default for all slash commands
# Default: 1 (the first campaign created by seed.py)
# CODEX_DEFAULT_CAMPAIGN_ID=1

# rclone remote path for Google Drive audio ingestion
# Default: living-codex-transcriptions
# CODEX_RCLONE_GDRIVE_PATH=living-codex-transcriptions

# Google Drive path for Craig-mode per-speaker folders (if using Craig bot)
# CODEX_GDRIVE_CRAIG_PATH=
